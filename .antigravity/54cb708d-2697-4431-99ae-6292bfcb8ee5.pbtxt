          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            } else if (isCompleted) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              bgClass = \'bg-emerald-500/10 border-emerald-500/20 text-emerald-700 dark:text-emerald-400\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
