        lines {
          text: "                          <label className=\"block text-[11px] font-bold text-neutral-500 mb-1\">{language === \'ar\' ? \'\330\261\331\202\331\205 \331\202\331\201\331\204 \330\247\331\204\330\271\330\262\331\204 \330\247\331\204\331\201\330\271\331\204\331\212 (LOTO Lock No):\' : \'LOTO Lock Lockout ID:\'}</label>"
