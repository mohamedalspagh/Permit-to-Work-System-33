    instruction: "Integrate push notifications into permit detail workflow event handlers"
    replacement_infos {
      original_chunk {
        target_content: "  // 1. Submit Draft\n  const handleSubmitDraft = () => {\n    const freshLog = createAuditEntry(\'\330\252\331\202\330\257\331\212\331\205 \330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\204\331\204\330\247\330\271\330\252\331\205\330\247\330\257 \330\247\331\204\331\205\330\250\330\257\330\246\331\212\', \'Submitted permit for approvals\', \'\330\252\330\243\331\203\331\212\330\257 \330\247\331\203\330\252\331\205\330\247\331\204 \331\205\330\252\330\267\331\204\330\250\330\247\330\252 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\210\330\247\331\204\331\205\331\202\330\247\331\210\331\204\331\212\331\206 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251.\');\n    \n    // Determine next state: if no department approval is required, go directly to HSE_REVIEW\n    const needsDept = permit.productionRequired || permit.electricalRequired;\n    const nextStatus: PermitStatus = needsDept ? \'PENDING_DEPT\' : \'HSE_REVIEW\';\n\n    onUpdatePermit({\n      ...permit,\n      status: nextStatus,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n  };\n\n  // 2. Production Approval or Reject\n  const handleProductionAction = (approve: boolean) => {\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\330\271\331\204\331\212\331\202 \330\243\331\210 \331\205\331\204\330\247\330\255\330\270\330\251 \331\205\330\250\330\261\330\261\330\251 \331\202\330\250\331\204 \330\247\331\204\330\247\330\271\330\252\331\205\330\247\330\257.\' : \'Please add a comment explaining your clearance review.\');\n      return;\n    }\n\n    const actionTextAr = approve ? \'\330\247\330\271\330\252\331\205\330\247\330\257 \331\210\330\245\331\202\330\261\330\247\330\261 \330\247\331\204\330\252\330\264\330\272\331\212\331\204 \331\210\330\247\331\204\330\245\331\206\330\252\330\247\330\254\' : \'\330\261\331\201\330\266 \330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\205\331\206 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\330\245\331\206\330\252\330\247\330\254\';\n    const actionTextEn = approve ? \'Approved production physical clearance\' : \'Rejected permit by Production Administration\';\n    \n    const freshLog = createAuditEntry(actionTextAr, actionTextEn, commentText);\n\n    let nextStatus = permit.status;\n    \n    if (approve) {\n      const isElectricalPending = permit.electricalRequired && !permit.electricalApproval;\n      // If electrical is required but not yet approved (and not current role), keep in PENDING_DEPT. \n      // Else, if Electrical is already approved (or not required), move to HSE_REVIEW!\n      nextStatus = isElectricalPending ? \'PENDING_DEPT\' : \'HSE_REVIEW\';\n    } else {\n      nextStatus = \'REJECTED\';\n    }\n\n    onUpdatePermit({\n      ...permit,\n      status: nextStatus,\n      productionApproval: approve,\n      productionApprover: \'\331\205. \330\252\330\261\331\203\331\212 \330\247\331\204\331\212\331\210\330\263\331\201\',\n      productionComment: commentText,\n      productionApprovedAt: new Date().toISOString().substring(0, 16),\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n    \n    setCommentText(\'\');\n  };\n\n  // 3. Electrical Approval with LOTO or Reject\n  const handleElectricalAction = (approve: boolean) => {\n    if (approve && permit.productionRequired && !permit.productionApproval) {\n      alert(language === \'ar\' \n        ? \'\330\271\330\260\330\261\330\247\331\213! \331\205\331\210\330\247\331\201\331\202\330\251 \331\210\330\247\330\271\330\252\331\205\330\247\330\257 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\330\245\331\206\330\252\330\247\330\254 \330\245\331\204\330\262\330\247\331\205\331\212\330\251 \331\202\330\250\331\204 \330\245\330\254\330\261\330\247\330\241 \330\247\331\204\330\271\330\262\331\204 \330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\246\331\212 \331\210\330\252\330\267\330\250\331\212\331\202 LOTO.\' \n        : \'Error! Production department approval and clearance are mandatory before completing electrical isolation and LOTO.\');\n      return;\n    }\n    if (approve && permit.lotoRequired && (!lotoLock.trim() || !lotoKey.trim())) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\252\331\210\330\253\331\212\331\202 \330\261\331\202\331\205 \331\202\331\201\331\204 \330\247\331\204\330\271\330\262\331\204 \331\210\330\261\331\202\331\205 \330\247\331\204\331\205\331\201\330\252\330\247\330\255 \331\204\330\252\330\243\331\205\331\212\331\206 LOTO.\' : \'LOTO lock and key numbers are required for physical electrical isolation.\');\n      return;\n    }\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\330\271\331\204\331\212\331\202 \331\205\330\250\330\261\330\261 \331\204\330\271\331\205\331\204\331\212\330\251 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251.\' : \'Please add a commentary details for lock isolation.\');\n      return;\n    }\n\n    const actionTextAr = approve \n      ? `\330\247\330\271\330\252\331\205\330\247\330\257 \330\256\330\267\330\251 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\210\330\252\330\267\330\250\331\212\331\202 \331\202\331\201\331\204 LOTO \330\261\331\202\331\205: ${lotoLock}`\n      : \'\330\261\331\201\330\266 \330\267\331\204\330\250 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\205\331\206 \331\202\330\250\331\204 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\241 \331\210\330\247\331\204\331\200 LOTO\';\n    const actionTextEn = approve \n      ? `Acknowledged electrical safety isolation, LOTO code: ${lotoLock}`\n      : \'Rejected electricity isolation request\';\n\n    const freshLog = createAuditEntry(actionTextAr, actionTextEn, commentText);\n\n    let nextStatus = permit.status;\n\n    if (approve) {\n      const isProductionPending = permit.productionRequired && !permit.productionApproval;\n      // Check if Production still needs to approve. If yes, stay in PENDING_DEPT. If no, advance to HSE_REVIEW!\n      nextStatus = isProductionPending ? \'PENDING_DEPT\' : \'HSE_REVIEW\';\n    } else {\n      nextStatus = \'REJECTED\';\n    }\n\n    onUpdatePermit({\n      ...permit,\n      status: nextStatus,\n      electricalApproval: approve,\n      electricalApprover: \'\331\205. \330\271\331\204\331\212 \330\271\330\250\330\257 \330\247\331\204\331\204\331\207\',\n      electricalComment: commentText,\n      electricalApprovedAt: new Date().toISOString().substring(0, 16),\n      lotoLockNumber: approve ? lotoLock : \'\',\n      lotoKeyNumber: approve ? lotoKey : \'\',\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };\n\n  // 4. HSE Gas Testing\n  const handlePerformGasTest = () => {\n    // Standard safety levels: O2 should be 19.5% to 23.5%. LEL < 10%. CO < 35 ppm.\n    const oxygenPassed = o2 >= 19.5 && o2 <= 23.5;\n    const lelPassed = lel < 10;\n    const coPassed = co < 35;\n    const passed = oxygenPassed && lelPassed && coPassed;\n\n    const testComment = `\331\202\330\261\330\247\330\241\330\247\330\252 \330\247\331\204\330\247\330\256\330\252\330\250\330\247\330\261 \330\247\331\204\330\260\330\247\330\252\331\212: \330\247\331\204\330\243\331\203\330\263\330\254\331\212\331\206 ${o2}% (${oxygenPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'})\330\214 \330\247\331\204\331\205\330\252\331\201\330\254\330\261\330\247\330\252 LEL %${lel} (${lelPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'})\330\214 \330\243\331\210\331\204 \330\243\331\203\330\263\331\212\330\257 \330\247\331\204\331\203\330\261\330\250\331\210\331\206 ${co}ppm (${coPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'}).`;\n    \n    const freshLog = createAuditEntry(\n      passed ? \'\331\201\330\255\330\265 \330\247\331\204\331\207\331\210\330\247\330\241 \331\210\330\247\331\204\330\272\330\247\330\262\330\247\330\252 \330\250\331\206\330\254\330\247\330\255\' : \'\330\245\330\254\330\261\330\247\330\241 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252 (\331\205\330\244\330\264\330\261\330\247\330\252 \330\256\330\267\330\261\330\251!)\', \n      passed ? \'Atmospheric gas assessment completed successfully\' : \'Atmospheric gas test failed safety thresholds\', \n      testComment\n    );\n\n    alert(passed \n      ? (language === \'ar\' ? \'\342\234\205 \330\247\331\204\331\207\331\210\330\247\330\241 \331\210\330\247\331\204\330\272\330\247\330\262\330\247\330\252 \331\205\330\267\330\247\330\250\331\202\330\251 \331\204\331\205\331\202\330\247\331\212\331\212\330\263 \330\247\331\204\330\263\331\204\330\247\331\205\330\251! \331\212\331\205\331\203\331\206\331\203 \330\247\331\204\330\242\331\206 \330\245\330\265\330\257\330\247\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255.\' : \'\342\234\205 Atmospheric test bounds passed. High safety margin established.\')\n      : (language === \'ar\' ? \'\342\235\214 \331\205\330\263\330\252\331\210\331\212\330\247\330\252 \330\256\330\267\331\212\330\261\330\251 \331\204\331\204\330\272\330\247\330\262 \330\247\331\204\330\256\330\247\331\206\331\202\330\214 \331\204\330\247 \330\252\330\265\330\257\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\210\330\257\330\271 \331\205\330\261\331\210\330\255\330\251 \330\247\331\204\330\264\331\201\330\267 \330\252\330\271\331\205\331\204 \331\204\330\261\330\250\330\271 \331\210\330\261\330\257\331\212\330\251!\' : \'\342\235\214 Dangerous respiratory metrics measured on-site! Hold authorization.\')\n    );\n\n    onUpdatePermit({\n      ...permit,\n      gasO2Level: o2,\n      gasLELLevel: lel,\n      gasCOLevel: co,\n      gasTestPassed: passed,\n      gasTester: \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      gasTestedAt: new Date().toISOString().substring(0, 16),\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setGasSubmitted(true);\n  };\n\n  // 5. HSE Final Issue (Approve) or Reject\n  const handleHseAction = (approve: boolean) => {\n    if (approve && permit.gasTestRequired && !permit.gasTestPassed) {\n      alert(language === \'ar\' ? \'\331\204\330\247 \331\212\331\205\331\203\331\206 \330\245\330\265\330\257\330\247\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\202\330\250\331\204 \330\245\330\254\330\261\330\247\330\241 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252 \331\210\330\252\330\254\330\247\331\210\330\262\331\207 \330\250\331\206\330\254\330\247\330\255!\' : \'Gas monitoring must pass safety limits prior to permit issuing.\');\n      return;\n    }\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\252\330\257\331\210\331\212\331\206 \330\247\331\204\330\252\331\210\330\254\331\212\331\207\330\247\330\252 \330\247\331\204\331\206\331\207\330\247\330\246\331\212\330\251 \331\204\330\263\331\204\330\247\331\205\330\251 \330\267\330\247\331\202\331\205 \330\247\331\204\330\271\331\205\331\204.\' : \'Please describe safety directions in your review comments.\');\n      return;\n    }\n\n    const actionTextAr = approve ? \'\330\245\330\265\330\257\330\247\330\261 \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \331\210\330\247\330\271\330\252\331\205\330\247\330\257\331\207 \330\263\330\247\330\261\331\212\330\247\331\213 \331\204\331\204\330\271\331\205\331\204\' : \'\330\261\331\201\330\266 \331\206\331\207\330\247\330\246\331\212 \331\204\330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \330\250\330\257\331\210\330\247\330\271\331\212 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \330\247\331\204\331\205\331\207\331\206\331\212\330\251\';\n    const actionTextEn = approve ? \'Authorized, issued and signed active PTW\' : \'Rejected permit request by HSE\';\n\n    const freshLog = createAuditEntry(actionTextAr, actionTextEn, commentText);\n\n    onUpdatePermit({\n      ...permit,\n      status: approve ? \'ACTIVE\' : \'REJECTED\',\n      hseApproval: approve,\n      hseApprover: \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      hseComment: commentText,\n      hseApprovedAt: new Date().toISOString().substring(0, 16),\n      safetyPrecautionConfirmations: checkedPrecautions,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };\n\n  // 6. Requester asks for Closure\n  const handleRequestClosure = () => {\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\330\271\331\204\331\212\331\202 \331\212\330\253\330\250\330\252 \330\256\330\261\331\210\330\254 \330\247\331\204\330\271\331\205\330\247\331\204 \331\210\331\201\331\203 \330\247\331\204\331\205\330\255\330\247\330\250\330\263 \331\205\331\212\331\203\330\247\331\206\331\212\331\203\331\212\330\247\331\213.\' : \'Please add remarks stating workers clearance and lock dismantle requests.\');\n      return;\n    }\n\n    const freshLog = createAuditEntry(\n      \'\330\252\331\202\330\257\331\212\331\205 \330\267\331\204\330\250 \330\245\330\272\331\204\330\247\331\202 \331\205\331\212\331\203\330\247\331\206\331\212\331\203\331\212 \331\210\331\205\331\212\330\257\330\247\331\206\331\212 \331\204\331\204\331\205\331\210\331\202\330\271\', \n      \'Requested chemical cleanup and mechanical license closure\', \n      commentText\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: \'PENDING_CLOSE\',\n      supervisorVerified: false, // Reset supervisor verification for closure audit\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };\n\n  // 6b. Safety Supervisor Field Checkpoint Verification\n  const handleSupervisorVerify = () => {\n    if (permit.gasTestRequired && !permit.gasTestPassed) {\n      alert(language === \'ar\' ? \'\331\204\330\247 \331\212\331\205\331\203\331\206 \330\245\331\203\331\205\330\247\331\204 \330\252\331\201\331\202\330\257 \330\247\331\204\331\205\330\264\330\261\331\201 \331\202\330\250\331\204 \330\245\330\254\330\261\330\247\330\241 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252 \331\210\330\252\330\254\330\247\331\210\330\262\331\207 \330\250\331\206\330\254\330\247\330\255!\' : \'Gas monitoring must pass safety limits prior to supervisor safety confirmation.\');\n      return;\n    }\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\331\210\330\254\331\212\331\207\330\247\330\252 \330\247\331\204\331\205\330\261\330\247\331\202\330\250\330\251 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251 \330\247\331\204\331\205\330\271\330\252\331\205\330\257\330\251 \331\205\331\206 \331\202\330\250\331\204\331\203\331\205.\' : \'Please add safety supervisor comments for the field audit record.\');\n      return;\n    }\n\n    const freshLog = createAuditEntry(\n      \'\330\252\330\253\330\250\330\252 \331\210\331\205\330\271\330\247\331\212\331\206\330\251 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \331\205\331\212\330\257\330\247\331\206\331\212\330\247\331\213 \331\210\330\245\330\265\330\257\330\247\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255\', \n      \'On-site safety checks verified and permit active release\', \n      commentText\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: \'ACTIVE\',\n      supervisorVerified: true,\n      supervisorVerifier: currentUser ? currentUser.fullNameAr : \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      supervisorVerifiedAt: new Date().toISOString().substring(0, 16),\n      supervisorComment: commentText,\n      hseApproval: true,\n      hseApprover: currentUser ? currentUser.fullNameAr : \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      hseApprovedAt: new Date().toISOString().substring(0, 16),\n      hseComment: commentText,\n      safetyPrecautionConfirmations: checkedPrecautions,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    alert(language === \'ar\' ? \'\342\234\223 \330\252\331\205 \330\252\330\263\330\254\331\212\331\204 \330\247\331\204\330\252\330\255\331\202\331\202 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212 \331\210\330\247\331\204\330\252\330\257\330\247\330\250\331\212\330\261 \330\247\331\204\331\210\331\202\330\247\330\246\331\212\330\251 \331\210\330\252\331\201\330\271\331\212\331\204 \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \330\250\331\206\330\254\330\247\330\255!\' : \'\342\234\223 Field verification completed. Permit is now ACTIVE for work.\');\n    setCommentText(\'\');\n  };\n\n  // 6c. Safety Supervisor Post-Work Environmental Handover Verification\n  const handleSupervisorCloseVerify = () => {\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\252\330\257\331\210\331\212\331\206 \330\255\330\247\331\204\330\251 \331\206\330\270\330\247\331\201\330\251 \331\205\330\255\331\212\330\267 \330\271\331\205\331\204 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\210\330\256\331\204\331\210 \330\247\331\204\331\205\331\210\331\202\330\271.\' : \'Please add field observations concerning housekeeping and site clearance.\');\n      return;\n    }\n\n    const freshLog = createAuditEntry(\n      \'\330\252\331\201\330\252\331\212\330\264 \330\247\331\204\331\206\330\270\330\247\331\201\330\251 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251 \331\210\330\245\330\272\331\204\330\247\331\202 \331\210\330\243\330\261\330\264\331\201\330\251 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\206\331\207\330\247\330\246\331\212\330\247\331\213\', \n      \'Post-work site cleanliness inspected and filed for final archival\', \n      commentText\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: \'CLOSED\',\n      supervisorVerified: true,\n      supervisorComment: `[\331\205\330\271\330\247\331\212\331\206\330\251 \330\247\331\204\331\206\330\270\330\247\331\201\330\251]: ${commentText}`,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    alert(language === \'ar\' ? \'\342\234\223 \330\252\331\205 \330\252\331\210\330\253\331\212\331\202 \330\247\331\204\331\205\330\271\330\247\331\212\331\206\330\251 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251 \331\210\330\245\330\272\331\204\330\247\331\202 \331\210\330\243\330\261\330\264\331\201\330\251 \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \330\250\331\206\330\254\330\247\330\255!\' : \'\342\234\223 Post-work checks completed and permit is archived as CLOSED.\');\n    setCommentText(\'\');\n  };\n\n  // 7. HSE Closes permit permanently\n  const handleFinalClose = () => {\n    const confirmation = window.confirm(\n      language === \'ar\' \n        ? \'\331\207\331\204 \330\252\330\244\331\203\330\257 \330\245\330\256\331\204\330\247\330\241 \330\247\331\204\331\205\331\210\331\202\330\271 \330\250\330\247\331\204\331\203\330\247\331\205\331\204 \331\205\331\206 \330\247\331\204\331\205\330\271\330\257\330\247\330\252 \331\210\331\206\330\270\330\247\331\201\330\251 \331\205\330\255\331\212\330\267 \330\247\331\204\330\271\331\205\331\204\330\214 \331\204\330\245\331\206\331\207\330\247\330\241 \330\252\331\201\330\271\331\212\331\204 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\210\330\243\330\261\330\264\331\201\330\252\331\207 \331\205\330\272\331\204\331\202\330\247\331\213\330\237\' \n        : \'Do you confirm that workers cleared the site, gears have been cleaned, and energy locks dismantled for final permit archival?\'\n    );\n\n    if (!confirmation) return;\n\n    const freshLog = createAuditEntry(\n      \'\331\205\330\271\330\247\331\212\331\206\330\251 \330\247\331\204\331\205\331\210\331\202\330\271 \331\210\330\252\330\243\331\203\331\212\330\257 \330\247\331\204\331\206\330\270\330\247\331\201\330\251 \331\210\330\245\330\272\331\204\330\247\331\202 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\206\331\207\330\247\330\246\331\212\330\247\331\213 \330\250\330\243\331\205\330\247\331\206\', \n      \'Site audit confirmed clean, filed and closed permanently\', \n      commentText || (language === \'ar\' ? \'\330\247\331\204\331\201\330\255\330\265 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212 \331\205\331\205\330\252\330\247\330\262\330\214 \330\252\331\205\330\252 \330\252\330\265\331\201\331\212\330\251 \330\247\331\204\330\243\331\202\331\201\330\247\331\204 \331\210\330\245\330\271\330\267\330\247\330\241 \330\245\330\260\331\206 \331\205\330\271\330\247\331\210\330\257\330\251 \330\247\331\204\330\252\330\264\330\272\331\212\331\204.\' : \'Physical check concluded. Site is clean. Power returned.\')\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: \'CLOSED\',\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };"
        replacement_content: "  // 1. Submit Draft\n  const handleSubmitDraft = () => {\n    const freshLog = createAuditEntry(\'\330\252\331\202\330\257\331\212\331\205 \330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\204\331\204\330\247\330\271\330\252\331\205\330\247\330\257 \330\247\331\204\331\205\330\250\330\257\330\246\331\212\', \'Submitted permit for approvals\', \'\330\252\330\243\331\203\331\212\330\257 \330\247\331\203\330\252\331\205\330\247\331\204 \331\205\330\252\330\267\331\204\330\250\330\247\330\252 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\210\330\247\331\204\331\205\331\202\330\247\331\210\331\204\331\212\331\206 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251.\');\n    \n    // Determine next state: if no department approval is required, go directly to HSE_REVIEW\n    const needsDept = permit.productionRequired || permit.electricalRequired;\n    const nextStatus: PermitStatus = needsDept ? \'PENDING_DEPT\' : \'HSE_REVIEW\';\n\n    // Push notification logic\n    const targetRole: SandboxRole = permit.productionRequired \n      ? \'PRODUCTION\' \n      : (permit.electricalRequired ? \'ELECTRICAL\' : \'HSE\');\n      \n    PushNotificationService.sendNotification(\n      language === \'ar\' ? `\360\237\232\250 \330\267\331\204\330\250 \330\252\330\265\330\261\331\212\330\255 \330\250\330\247\331\206\330\252\330\270\330\247\330\261 \330\247\331\204\330\247\330\254\330\261\330\247\330\241: ${permit.id}` : `\360\237\232\250 Permit Awaiting Action: ${permit.id}`,\n      language === \'ar\'\n        ? `\330\267\331\204\330\250 \330\252\330\265\330\261\331\212\330\255 \"${permit.title}\" \331\201\331\212 \"${permit.location}\" \330\250\330\247\331\206\330\252\330\270\330\247\330\261 \330\252\330\257\330\247\330\250\331\212\330\261 \330\247\331\204\330\271\330\262\331\204 \330\247\331\204\330\252\330\264\330\272\331\212\331\204\331\212 \331\210\330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\246\331\212.`\n        : `Permit \"${permit.title}\" in \"${permit.location}\" is pending isolation/clearance reviews.`,\n      {\n        targetRole,\n        permitId: permit.id,\n        actionRequired: true\n      }\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: nextStatus,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n  };\n\n  // 2. Production Approval or Reject\n  const handleProductionAction = (approve: boolean) => {\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\330\271\331\204\331\212\331\202 \330\243\331\210 \331\205\331\204\330\247\330\255\330\270\330\251 \331\205\330\250\330\261\330\261\330\251 \331\202\330\250\331\204 \330\247\331\204\330\247\330\271\330\252\331\205\330\247\330\257.\' : \'Please add a comment explaining your clearance review.\');\n      return;\n    }\n\n    const actionTextAr = approve ? \'\330\247\330\271\330\252\331\205\330\247\330\257 \331\210\330\245\331\202\330\261\330\247\330\261 \330\247\331\204\330\252\330\264\330\272\331\212\331\204 \331\210\330\247\331\204\330\245\331\206\330\252\330\247\330\254\' : \'\330\261\331\201\330\266 \330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\205\331\206 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\330\245\331\206\330\252\330\247\330\254\';\n    const actionTextEn = approve ? \'Approved production physical clearance\' : \'Rejected permit by Production Administration\';\n    \n    const freshLog = createAuditEntry(actionTextAr, actionTextEn, commentText);\n\n    let nextStatus = permit.status;\n    \n    if (approve) {\n      const isElectricalPending = permit.electricalRequired && !permit.electricalApproval;\n      // If electrical is required but not yet approved (and not current role), keep in PENDING_DEPT. \n      // Else, if Electrical is already approved (or not required), move to HSE_REVIEW!\n      nextStatus = isElectricalPending ? \'PENDING_DEPT\' : \'HSE_REVIEW\';\n      \n      // Notify next role\n      if (isElectricalPending) {\n        PushNotificationService.sendNotification(\n          language === \'ar\' ? `\342\232\241 \330\271\330\262\331\204 \331\203\331\207\330\261\330\250\330\247\330\246\331\212 \331\205\330\267\331\204\331\210\330\250: ${permit.id}` : `\342\232\241 Electrical Isolation Needed: ${permit.id}`,\n          language === \'ar\'\n            ? `\330\247\330\271\330\252\331\205\330\257\330\252 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\330\245\331\206\330\252\330\247\330\254 \330\256\331\204\331\210 \330\247\331\204\331\205\331\210\331\202\330\271. \331\212\330\261\330\254\331\211 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\210\330\252\330\253\330\250\331\212\330\252 \330\243\331\202\331\201\330\247\331\204 LOTO.`\n            : `Production clearance received. Electrical isolation & LOTO padlocks are now required.`,\n          {\n            targetRole: \'ELECTRICAL\',\n            permitId: permit.id,\n            actionRequired: true\n          }\n        );\n      } else {\n        PushNotificationService.sendNotification(\n          language === \'ar\' ? `\360\237\233\241\357\270\217 \331\205\330\271\330\247\331\212\331\206\330\251 \331\210\331\205\330\261\330\247\330\254\330\271\330\251 \330\263\331\204\330\247\331\205\330\251: ${permit.id}` : `\360\237\233\241\357\270\217 HSE Review Required: ${permit.id}`,\n          language === \'ar\'\n            ? `\330\252\331\205 \330\247\331\204\330\255\330\265\331\210\331\204 \330\271\331\204\331\211 \331\205\331\210\330\247\331\201\331\202\330\247\330\252 \330\247\331\204\330\245\330\257\330\247\330\261\330\247\330\252. \330\250\330\247\331\206\330\252\330\270\330\247\330\261 \330\252\330\257\331\202\331\212\331\202 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \331\210\331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252.`\n            : `Department clearances obtained. Awaiting HSE supervisor on-site safety checks & gas monitoring.`,\n          {\n            targetRole: \'HSE\',\n            permitId: permit.id,\n            actionRequired: true\n          }\n        );\n      }\n    } else {\n      nextStatus = \'REJECTED\';\n      \n      PushNotificationService.sendNotification(\n        language === \'ar\' ? `\342\235\214 \330\261\331\201\330\266 \330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255: ${permit.id}` : `\342\235\214 Permit Request Rejected: ${permit.id}`,\n        language === \'ar\'\n          ? `\330\252\331\205 \330\261\331\201\330\266 \330\247\331\204\330\267\331\204\330\250 \331\205\331\206 \331\205. \330\252\330\261\331\203\331\212 (\330\247\331\204\330\245\331\206\330\252\330\247\330\254): ${commentText}`\n          : `Permit was rejected by Production Manager Turki: ${commentText}`,\n        {\n          targetRole: \'REQUESTER\',\n          permitId: permit.id,\n          actionRequired: false\n        }\n      );\n    }\n\n    onUpdatePermit({\n      ...permit,\n      status: nextStatus,\n      productionApproval: approve,\n      productionApprover: \'\331\205. \330\252\330\261\331\203\331\212 \330\247\331\204\331\212\331\210\330\263\331\201\',\n      productionComment: commentText,\n      productionApprovedAt: new Date().toISOString().substring(0, 16),\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n    \n    setCommentText(\'\');\n  };\n\n  // 3. Electrical Approval with LOTO or Reject\n  const handleElectricalAction = (approve: boolean) => {\n    if (approve && permit.productionRequired && !permit.productionApproval) {\n      alert(language === \'ar\' \n        ? \'\330\271\330\260\330\261\330\247\331\213! \331\205\331\210\330\247\331\201\331\202\330\251 \331\210\330\247\330\271\330\252\331\205\330\247\330\257 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\330\245\331\206\330\252\330\247\330\254 \330\245\331\204\330\262\330\247\331\205\331\212\330\251 \331\202\330\250\331\204 \330\245\330\254\330\261\330\247\330\241 \330\247\331\204\330\271\330\262\331\204 \330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\246\331\212 \331\210\330\252\330\267\330\250\331\212\331\202 LOTO.\' \n        : \'Error! Production department approval and clearance are mandatory before completing electrical isolation and LOTO.\');\n      return;\n    }\n    if (approve && permit.lotoRequired && (!lotoLock.trim() || !lotoKey.trim())) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\252\331\210\330\253\331\212\331\202 \330\261\331\202\331\205 \331\202\331\201\331\204 \330\247\331\204\330\271\330\262\331\204 \331\210\330\261\331\202\331\205 \330\247\331\204\331\205\331\201\330\252\330\247\330\255 \331\204\330\252\330\243\331\205\331\212\331\206 LOTO.\' : \'LOTO lock and key numbers are required for physical electrical isolation.\');\n      return;\n    }\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\330\271\331\204\331\212\331\202 \331\205\330\250\330\261\330\261 \331\204\330\271\331\205\331\204\331\212\330\251 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251.\' : \'Please add a commentary details for lock isolation.\');\n      return;\n    }\n\n    const actionTextAr = approve \n      ? `\330\247\330\271\330\252\331\205\330\247\330\257 \330\256\330\267\330\251 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\210\330\252\330\267\330\250\331\212\331\202 \331\202\331\201\331\204 LOTO \330\261\331\202\331\205: ${lotoLock}`\n      : \'\330\261\331\201\330\266 \330\267\331\204\330\250 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\205\331\206 \331\202\330\250\331\204 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\241 \331\210\330\247\331\204\331\200 LOTO\';\n    const actionTextEn = approve \n      ? `Acknowledged electrical safety isolation, LOTO code: ${lotoLock}`\n      : \'Rejected electricity isolation request\';\n\n    const freshLog = createAuditEntry(actionTextAr, actionTextEn, commentText);\n\n    let nextStatus = permit.status;\n\n    if (approve) {\n      const isProductionPending = permit.productionRequired && !permit.productionApproval;\n      // Check if Production still needs to approve. If yes, stay in PENDING_DEPT. If no, advance to HSE_REVIEW!\n      nextStatus = isProductionPending ? \'PENDING_DEPT\' : \'HSE_REVIEW\';\n      \n      if (isProductionPending) {\n        PushNotificationService.sendNotification(\n          language === \'ar\' ? `\360\237\217\227\357\270\217 \330\256\331\204\331\210 \330\256\330\267 \330\247\331\204\330\252\330\264\330\272\331\212\331\204 \331\205\330\267\331\204\331\210\330\250: ${permit.id}` : `\360\237\217\227\357\270\217 Production Clearance Needed: ${permit.id}`,\n          language === \'ar\'\n            ? `\330\252\331\205 \330\271\330\262\331\204 \330\247\331\204\331\204\331\210\330\255\330\247\330\252 \331\210\330\252\330\253\330\250\331\212\330\252 \330\243\331\202\331\201\330\247\331\204 LOTO. \331\212\330\261\330\254\331\211 \330\245\331\212\331\202\330\247\331\201 \330\247\331\204\331\205\330\272\330\260\331\212\330\247\330\252 \331\210\330\247\331\204\330\263\331\212\331\210\330\261 \331\205\331\212\331\203\330\247\331\206\331\212\331\203\331\212\330\247\331\213.`\n            : `Electrical LOTO complete. Awaiting Production department physical clearance.`,\n          {\n            targetRole: \'PRODUCTION\',\n            permitId: permit.id,\n            actionRequired: true\n          }\n        );\n      } else {\n        PushNotificationService.sendNotification(\n          language === \'ar\' ? `\360\237\233\241\357\270\217 \331\205\330\261\330\247\330\254\330\271\330\251 \331\210\331\201\330\255\330\265 \330\263\331\204\330\247\331\205\330\251: ${permit.id}` : `\360\237\233\241\357\270\217 HSE Review Required: ${permit.id}`,\n          language === \'ar\'\n            ? `\330\252\331\205 \330\247\331\203\330\252\331\205\330\247\331\204 \330\271\330\262\331\204 LOTO \331\210\330\247\331\204\331\205\331\210\330\247\331\201\331\202\330\247\330\252 \330\247\331\204\330\252\330\264\330\272\331\212\331\204\331\212\330\251. \330\250\330\247\331\206\330\252\330\270\330\247\330\261 \330\252\330\257\331\202\331\212\331\202 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \331\210\331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252.`\n            : `LOTO lock-out complete. Awaiting HSE supervisor on-site safety review & gas test.`,\n          {\n            targetRole: \'HSE\',\n            permitId: permit.id,\n            actionRequired: true\n          }\n        );\n      }\n    } else {\n      nextStatus = \'REJECTED\';\n      \n      PushNotificationService.sendNotification(\n        language === \'ar\' ? `\342\235\214 \330\261\331\201\330\266 \331\202\331\201\331\204 LOTO \331\210\330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251: ${permit.id}` : `\342\235\214 LOTO Isolation Rejected: ${permit.id}`,\n        language === \'ar\'\n          ? `\330\252\331\205 \330\261\331\201\330\266 \330\267\331\204\330\250 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\205\331\206 \331\205. \330\271\331\204\331\212 (\330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\241): ${commentText}`\n          : `Energy isolation rejected by Electrical Manager Ali: ${commentText}`,\n        {\n          targetRole: \'REQUESTER\',\n          permitId: permit.id,\n          actionRequired: false\n        }\n      );\n    }\n\n    onUpdatePermit({\n      ...permit,\n      status: nextStatus,\n      electricalApproval: approve,\n      electricalApprover: \'\331\205. \330\271\331\204\331\212 \330\271\330\250\330\257 \330\247\331\204\331\204\331\207\',\n      electricalComment: commentText,\n      electricalApprovedAt: new Date().toISOString().substring(0, 16),\n      lotoLockNumber: approve ? lotoLock : \'\',\n      lotoKeyNumber: approve ? lotoKey : \'\',\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };\n\n  // 4. HSE Gas Testing\n  const handlePerformGasTest = () => {\n    // Standard safety levels: O2 should be 19.5% to 23.5%. LEL < 10%. CO < 35 ppm.\n    const oxygenPassed = o2 >= 19.5 && o2 <= 23.5;\n    const lelPassed = lel < 10;\n    const coPassed = co < 35;\n    const passed = oxygenPassed && lelPassed && coPassed;\n\n    const testComment = `\331\202\330\261\330\247\330\241\330\247\330\252 \330\247\331\204\330\247\330\256\330\252\330\250\330\247\330\261 \330\247\331\204\330\260\330\247\330\252\331\212: \330\247\331\204\330\243\331\203\330\263\330\254\331\212\331\206 ${o2}% (${oxygenPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'})\330\214 \330\247\331\204\331\205\330\252\331\201\330\254\330\261\330\247\330\252 LEL %${lel} (${lelPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'})\330\214 \330\243\331\210\331\204 \330\243\331\203\330\263\331\212\330\257 \330\247\331\204\331\203\330\261\330\250\331\210\331\206 ${co}ppm (${coPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'}).`;\n    \n    const freshLog = createAuditEntry(\n      passed ? \'\331\201\330\255\330\265 \330\247\331\204\331\207\331\210\330\247\330\241 \331\210\330\247\331\204\330\272\330\247\330\262\330\247\330\252 \330\250\331\206\330\254\330\247\330\255\' : \'\330\245\330\254\330\261\330\247\330\241 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252 (\331\205\330\244\330\264\330\261\330\247\330\252 \330\256\330\267\330\261\330\251!)\', \n      passed ? \'Atmospheric gas assessment completed successfully\' : \'Atmospheric gas test failed safety thresholds\', \n      testComment\n    );\n\n    // Notify of gas test results\n    PushNotificationService.sendNotification(\n      language === \'ar\' ? `\360\237\222\250 \331\206\330\252\331\212\330\254\330\251 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252: ${permit.id}` : `\360\237\222\250 Gas Test Result: ${permit.id}`,\n      language === \'ar\'\n        ? `\330\252\331\205 \331\201\330\255\330\265 \330\247\331\204\331\207\331\210\330\247\330\241: \330\247\331\204\330\243\331\203\330\263\330\254\331\212\331\206 ${o2}%\330\214 \330\247\331\204\331\205\330\252\331\201\330\254\330\261\330\247\330\252 %${lel}\330\214 \330\243\331\210\331\204 \330\243\331\203\330\263\331\212\330\257 \330\247\331\204\331\203\330\261\330\250\331\210\331\206 ${co}ppm. \330\247\331\204\331\206\330\252\331\212\330\254\330\251: ${passed ? \'\331\205\330\267\330\247\330\250\331\202 \331\210\330\242\331\205\331\206 \342\234\205\' : \'\330\256\330\267\330\261\330\251 \331\210\330\272\331\212\330\261 \331\205\330\267\330\247\330\250\331\202\330\251 \342\235\214\'}`\n        : `Gas values: O2: ${o2}%, LEL: ${lel}%, CO: ${co}ppm. Status: ${passed ? \'Safe \342\234\205\' : \'Danger Threshold Exceeded \342\235\214\'}`,\n      {\n        targetRole: \'HSE\',\n        permitId: permit.id,\n        actionRequired: passed\n      }\n    );\n\n    alert(passed \n      ? (language === \'ar\' ? \'\342\234\205 \330\247\331\204\331\207\331\210\330\247\330\241 \331\210\330\247\331\204\330\272\330\247\330\262\330\247\330\252 \331\205\330\267\330\247\330\250\331\202\330\251 \331\204\331\205\331\202\330\247\331\212\331\212\330\263 \330\247\331\204\330\263\331\204\330\247\331\205\330\251! \331\212\331\205\331\203\331\206\331\203 \330\247\331\204\330\242\331\206 \330\245\330\265\330\257\330\247\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255.\' : \'\342\234\205 Atmospheric test bounds passed. High safety margin established.\')\n      : (language === \'ar\' ? \'\342\235\214 \331\205\330\263\330\252\331\210\331\212\330\247\330\252 \330\256\330\267\331\212\330\261\330\251 \331\204\331\204\330\272\330\247\330\262 \330\247\331\204\330\256\330\247\331\206\331\202\330\214 \331\204\330\247 \330\252\330\265\330\257\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\210\330\257\330\271 \331\205\330\261\331\210\330\255\330\251 \330\247\331\204\330\264\331\201\330\267 \330\252\330\271\331\205\331\204 \331\204\330\261\330\250\330\271 \331\210\330\261\330\257\331\212\330\251!\' : \'\342\235\214 Dangerous respiratory metrics measured on-site! Hold authorization.\')\n    );\n\n    onUpdatePermit({\n      ...permit,\n      gasO2Level: o2,\n      gasLELLevel: lel,\n      gasCOLevel: co,\n      gasTestPassed: passed,\n      gasTester: \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      gasTestedAt: new Date().toISOString().substring(0, 16),\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setGasSubmitted(true);\n  };\n\n  // 5. HSE Final Issue (Approve) or Reject\n  const handleHseAction = (approve: boolean) => {\n    if (approve && permit.gasTestRequired && !permit.gasTestPassed) {\n      alert(language === \'ar\' ? \'\331\204\330\247 \331\212\331\205\331\203\331\206 \330\245\330\265\330\257\330\247\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\202\330\250\331\204 \330\245\330\254\330\261\330\247\330\241 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252 \331\210\330\252\330\254\330\247\331\210\330\262\331\207 \330\250\331\206\330\254\330\247\330\255!\' : \'Gas monitoring must pass safety limits prior to permit issuing.\');\n      return;\n    }\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\252\330\257\331\210\331\212\331\206 \330\247\331\204\330\252\331\210\330\254\331\212\331\207\330\247\330\252 \330\247\331\204\331\206\331\207\330\247\330\246\331\212\330\251 \331\204\330\263\331\204\330\247\331\205\330\251 \330\267\330\247\331\202\331\205 \330\247\331\204\330\271\331\205\331\204.\' : \'Please describe safety directions in your review comments.\');\n      return;\n    }\n\n    const actionTextAr = approve ? \'\330\245\330\265\330\257\330\247\330\261 \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \331\210\330\247\330\271\330\252\331\205\330\247\330\257\331\207 \330\263\330\247\330\261\331\212\330\247\331\213 \331\204\331\204\330\271\331\205\331\204\' : \'\330\261\331\201\330\266 \331\206\331\207\330\247\330\246\331\212 \331\204\330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \330\250\330\257\331\210\330\247\330\271\331\212 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \330\247\331\204\331\205\331\207\331\206\331\212\330\251\';\n    const actionTextEn = approve ? \'Authorized, issued and signed active PTW\' : \'Rejected permit request by HSE\';\n\n    const freshLog = createAuditEntry(actionTextAr, actionTextEn, commentText);\n\n    // Notify requester\n    if (approve) {\n      PushNotificationService.sendNotification(\n        language === \'ar\' ? `\342\234\205 \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \330\254\330\247\331\207\330\262 \331\210\331\206\330\264\330\267: ${permit.id}` : `\342\234\205 Permit Is Now ACTIVE: ${permit.id}`,\n        language === \'ar\'\n          ? `\330\247\330\271\330\252\331\205\330\257\330\252 \330\245\330\257\330\247\330\261\330\251 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \330\252\330\265\330\261\331\212\330\255 \"${permit.title}\" \331\210\331\207\331\210 \330\254\330\247\331\207\330\262 \331\204\330\250\330\257\330\241 \330\247\331\204\330\271\331\205\331\204 \331\201\331\212 \330\247\331\204\331\205\331\210\331\202\330\271 \330\252\330\255\330\252 \330\245\330\264\330\261\330\247\331\201\331\203.`\n          : `Safety Department approved & issued permit \"${permit.title}\". Site work is authorized to start under EHS compliance.`,\n        {\n          targetRole: \'REQUESTER\',\n          permitId: permit.id,\n          actionRequired: false\n        }\n      );\n    } else {\n      PushNotificationService.sendNotification(\n        language === \'ar\' ? `\342\235\214 \330\261\331\201\330\266 \330\267\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\206\331\207\330\247\330\246\331\212\330\247\331\213: ${permit.id}` : `\342\235\214 Permit Final Rejection: ${permit.id}`,\n        language === \'ar\'\n          ? `\330\252\331\205 \330\261\331\201\330\266 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\206\331\207\330\247\330\246\331\212\330\247\331\213 \331\205\331\206 \331\205. \330\243\330\263\330\271\330\257 (HSE): ${commentText}`\n          : `Permit was rejected by HSE Safety Supervisor Asaad: ${commentText}`,\n        {\n          targetRole: \'REQUESTER\',\n          permitId: permit.id,\n          actionRequired: false\n        }\n      );\n    }\n\n    onUpdatePermit({\n      ...permit,\n      status: approve ? \'ACTIVE\' : \'REJECTED\',\n      hseApproval: approve,\n      hseApprover: \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      hseComment: commentText,\n      hseApprovedAt: new Date().toISOString().substring(0, 16),\n      safetyPrecautionConfirmations: checkedPrecautions,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };\n\n  // 6. Requester asks for Closure\n  const handleRequestClosure = () => {\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\330\271\331\204\331\212\331\202 \331\212\330\253\330\250\330\252 \330\256\330\261\331\210\330\254 \330\247\331\204\330\271\331\205\330\247\331\204 \331\210\331\201\331\203 \330\247\331\204\331\205\330\255\330\247\330\250\330\263 \331\205\331\212\331\203\330\247\331\206\331\212\331\203\331\212\330\247\331\213.\' : \'Please add remarks stating workers clearance and lock dismantle requests.\');\n      return;\n    }\n\n    const freshLog = createAuditEntry(\n      \'\330\252\331\202\330\257\331\212\331\205 \330\267\331\204\330\250 \330\245\330\272\331\204\330\247\331\202 \331\205\331\212\331\203\330\247\331\206\331\212\331\203\331\212 \331\210\331\205\331\212\330\257\330\247\331\206\331\212 \331\204\331\204\331\205\331\210\331\202\330\271\', \n      \'Requested chemical cleanup and mechanical license closure\', \n      commentText\n    );\n\n    // Notify HSE\n    PushNotificationService.sendNotification(\n      language === \'ar\' ? `\360\237\247\271 \330\267\331\204\330\250 \330\245\330\272\331\204\330\247\331\202 \331\210\330\252\331\201\330\252\331\212\330\264 \331\206\330\270\330\247\331\201\330\251 \330\247\331\204\331\205\331\210\331\202\330\271: ${permit.id}` : `\360\237\247\271 Housekeeping & Closure Audit Required: ${permit.id}`,\n      language === \'ar\'\n        ? `\331\202\330\247\331\205 \331\205. \330\243\330\255\331\205\330\257 \330\250\330\245\331\206\331\207\330\247\330\241 \330\243\330\271\331\205\330\247\331\204 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\210\330\252\330\265\331\201\331\212\330\251 \330\247\331\204\330\271\331\205\330\247\331\204 \331\201\331\212 \330\252\330\265\330\261\331\212\330\255 \"${permit.title}\". \331\212\330\261\330\254\331\211 \330\252\331\201\330\252\331\212\330\264 \330\247\331\204\331\205\331\210\331\202\330\271 \331\210\330\245\330\272\331\204\330\247\331\202 LOTO.`\n        : `Eng. Ahmed reported maintenance work complete & site cleared for permit \"${permit.title}\". Please inspect housekeeping & archive.`,\n      {\n        targetRole: \'HSE\',\n        permitId: permit.id,\n        actionRequired: true\n      }\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: \'PENDING_CLOSE\',\n      supervisorVerified: false, // Reset supervisor verification for closure audit\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    setCommentText(\'\');\n  };\n\n  // 6b. Safety Supervisor Field Checkpoint Verification\n  const handleSupervisorVerify = () => {\n    if (permit.gasTestRequired && !permit.gasTestPassed) {\n      alert(language === \'ar\' ? \'\331\204\330\247 \331\212\331\205\331\203\331\206 \330\245\331\203\331\205\330\247\331\204 \330\252\331\201\331\202\330\257 \330\247\331\204\331\205\330\264\330\261\331\201 \331\202\330\250\331\204 \330\245\330\254\330\261\330\247\330\241 \331\201\330\255\330\265 \330\247\331\204\330\272\330\247\330\262\330\247\330\252 \331\210\330\252\330\254\330\247\331\210\330\262\331\207 \330\250\331\206\330\254\330\247\330\255!\' : \'Gas monitoring must pass safety limits prior to supervisor safety confirmation.\');\n      return;\n    }\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\245\330\257\330\256\330\247\331\204 \330\252\331\210\330\254\331\212\331\207\330\247\330\252 \330\247\331\204\331\205\330\261\330\247\331\202\330\250\330\251 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251 \330\247\331\204\331\205\330\271\330\252\331\205\330\257\330\251 \331\205\331\206 \331\202\330\250\331\204\331\203\331\205.\' : \'Please add safety supervisor comments for the field audit record.\');\n      return;\n    }\n\n    const freshLog = createAuditEntry(\n      \'\330\252\330\253\330\250\330\252 \331\210\331\205\330\271\330\247\331\212\331\206\330\251 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \331\205\331\212\330\257\330\247\331\206\331\212\330\247\331\213 \331\210\330\245\330\265\330\257\330\247\330\261 \330\247\331\204\330\252\330\265\330\261\331\212\330\255\', \n      \'On-site safety checks verified and permit active release\', \n      commentText\n    );\n\n    const verifierName = currentUser ? currentUser.fullNameAr : \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\';\n\n    // Notify requester\n    PushNotificationService.sendNotification(\n      language === \'ar\' ? `\342\234\205 \330\252\331\201\330\271\331\212\331\204 \331\210\330\252\330\257\331\202\331\212\331\202 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \330\250\330\247\331\204\331\205\331\212\330\257\330\247\331\206: ${permit.id}` : `\342\234\205 Field Inspection Complete (Active): ${permit.id}`,\n      language === \'ar\'\n        ? `\330\243\330\254\330\261\331\211 \330\247\331\204\331\205\330\264\330\261\331\201 ${verifierName} \331\205\330\271\330\247\331\212\331\206\330\251 \331\204\331\204\331\205\331\210\331\202\330\271 \331\210\330\247\330\271\330\252\331\205\330\257 \330\263\331\204\330\247\331\205\330\251 \330\247\331\204\330\252\330\257\330\247\330\250\331\212\330\261 \330\247\331\204\331\210\331\202\330\247\330\246\331\212\330\251. \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \331\206\330\264\330\267 \330\247\331\204\330\242\331\206.`\n        : `EHS Supervisor ${verifierName} completed on-site audit. The permit is now fully ACTIVE.`,\n      {\n        targetRole: \'REQUESTER\',\n        permitId: permit.id,\n        actionRequired: false\n      }\n    );\n\n    onUpdatePermit({\n      ...permit,\n      status: \'ACTIVE\',\n      supervisorVerified: true,\n      supervisorVerifier: currentUser ? currentUser.fullNameAr : \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      supervisorVerifiedAt: new Date().toISOString().substring(0, 16),\n      supervisorComment: commentText,\n      hseApproval: true,\n      hseApprover: currentUser ? currentUser.fullNameAr : \'\331\205. \330\243\330\263\330\271\330\257 \330\247\331\204\330\264\331\205\330\261\330\247\331\206\331\212\',\n      hseApprovedAt: new Date().toISOString().substring(0, 16),\n      hseComment: commentText,\n      safetyPrecautionConfirmations: checkedPrecautions,\n      auditTrail: [...permit.auditTrail, freshLog]\n    });\n\n    alert(language === \'ar\' ? \'\342\234\223 \330\252\331\205 \330\252\330\263\330\254\331\212\331\204 \330\247\331\204\330\252\330\255\331\202\331\202 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212 \331\210\330\247\331\204\330\252\330\257\330\247\330\250\331\212\330\261 \330\247\331\204\331\210\331\202\330\247\330\246\331\212\330\251 \331\210\330\252\331\201\330\271\331\212\331\204 \330\252\330\265\330\261\331\212\330\255 \330\247\331\204\330\271\331\205\331\204 \330\250\331\206\330\254\330\247\330\255!\' : \'\342\234\223 Field verification completed. Permit is now ACTIVE for work.\');\n    setCommentText(\'\');\n  };\n\n  // 6c. Safety Supervisor Post-Work Environmental Handover Verification\n  const handleSupervisorCloseVerify = () => {\n    if (!commentText.trim()) {\n      alert(language === \'ar\' ? \'\330\247\331\204\330\261\330\254\330\247\330\241 \330\252\330\257\331\210\331\212\331\206 \330\255\330\247\331\204\330\251 \331\206\330\270\330\247\331\201\330\251 \331\205\330\255\331\212\330\267 \330\271\331\205\331\204 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\210\330\256\331\204\331\210 \330\247\331\204\331\205\331\210\331\202\330\271.\' : \'Please add field observations concerning housekeeping and site clearance.\');\n      return;\n    }\n\n    const freshLog = createAuditEntry(\n      \'\330\252\331\201\330\252\331\212\330\264 \330\247\331\204\331\206\330\270\330\247\331\201\330\251 \330\247\331\204\331\205\331\212\330\257\330\247\331\206\331\212\330\251 \331\210\330\245\330\272\331\204\330\247\331\202 \331\210\330\243\330\