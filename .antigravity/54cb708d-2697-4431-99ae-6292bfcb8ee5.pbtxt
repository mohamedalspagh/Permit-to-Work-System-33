        lines {
          text: "            const statusesOrder: PermitStatus[] = [\'DRAFT\', \'PENDING_DEPT\', \'HSE_REVIEW\', \'ACTIVE\', \'PENDING_CLOSE\', \'CLOSED\'];"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
