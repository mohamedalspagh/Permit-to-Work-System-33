        }
        lines {
          text: "    const testComment = `\331\202\330\261\330\247\330\241\330\247\330\252 \330\247\331\204\330\247\330\256\330\252\330\250\330\247\330\261 \330\247\331\204\330\260\330\247\330\252\331\212: \330\247\331\204\330\243\331\203\330\263\330\254\331\212\331\206 ${o2}% (${oxygenPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'})\330\214 \330\247\331\204\331\205\330\252\331\201\330\254\330\261\330\247\330\252 LEL %${lel} (${lelPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'})\330\214 \330\243\331\210\331\204 \330\243\331\203\330\263\331\212\330\257 \330\247\331\204\331\203\330\261\330\250\331\210\331\206 ${co}ppm (${coPassed ? \'\330\242\331\205\331\206\' : \'\331\205\330\256\330\247\331\204\331\201\'}).`;"
