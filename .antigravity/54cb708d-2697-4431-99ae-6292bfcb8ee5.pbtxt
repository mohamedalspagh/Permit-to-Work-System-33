        lines {
          text: "                      {language === \'ar\' ? `\342\234\223 \331\205\330\271\330\252\331\205\330\257 \331\205\331\206 ${permit.productionApprover}` : `\342\234\223 Approved by ${permit.productionApprover}`}"
