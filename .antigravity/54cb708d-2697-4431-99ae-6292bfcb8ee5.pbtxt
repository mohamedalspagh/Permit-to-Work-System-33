          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <h5 className=\"text-xs font-extrabold text-neutral-450 uppercase\">{language === \'ar\' ? \'\330\245\330\254\330\261\330\247\330\241 \330\271\330\262\331\204 \330\247\331\204\330\267\330\247\331\202\330\251 \331\210\330\247\331\204\331\200 LOTO \331\210\330\252\330\243\331\205\331\212\331\206 \330\247\331\204\331\204\331\210\330\255\330\247\330\252 (\330\245\330\257\330\247\330\261\330\251 \330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\241)\' : \'Electrical Safety & Lockout/Tagout (LOTO)\'}</h5>"
