          text: "            const isCurrent = permit.status === step.key;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isCompleted = stepIdx < currentIdx && permit.status !== \'REJECTED\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
