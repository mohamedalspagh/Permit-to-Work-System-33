        lines {
          text: "                      <label className=\"block text-xs font-bold text-neutral-500 text-right\">{language === \'ar\' ? \'\330\252\331\202\330\261\331\212\330\261 \331\205\330\271\330\247\331\212\331\206\330\251 \330\247\331\204\331\205\331\210\331\202\330\271 \331\210\330\256\330\267\330\251 \330\247\331\204\330\245\331\212\331\202\330\247\331\201 \331\205\331\212\331\203\330\247\331\206\331\212\331\203\331\212\330\247\331\213:\' : \'Production comments & line isolation status:\'}</label>"
