p className=\"text-xs\">\n                        {language === \'ar\' ? \'\331\204\331\205 \331\212\330\252\331\205 \330\257\331\201\330\271 \330\243\331\212 \330\245\330\264\330\271\330\247\330\261 \331\201\331\210\330\261\331\212 \330\250\330\271\330\257\' : \'No push notifications received yet\'}\n                      </p>\n                      <p className=\"text-[10px] text-slate-400 mt-1 max-w-[180px] mx-auto\">\n                        {language === \'ar\' \n                          ? \'\331\202\331\205 \330\250\330\252\331\202\330\257\331\212\331\205 \330\243\331\210 \330\247\330\271\330\252\331\205\330\247\330\257 \330\252\330\265\330\247\330\261\331\212\330\255 \331\204\330\252\330\264\330\272\331\212\331\204 \330\252\331\206\330\250\331\212\331\207\330\247\330\252 \330\247\331\204\331\207\331\210\330\247\330\252\331\201 \330\247\331\204\331\201\331\210\330\261\331\212\330\251.\' \n                          : \'Submit or clearance a permit to see immediate alerts trigger.\'}\n                      </p>\n                    </div>\n                  )}\n                </div>\n              </div>\n            )}\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
