        lines {
          text: "                ? \'\331\202\330\257\331\205 \330\267\330\247\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \330\245\331\202\330\261\330\247\330\261\330\247\331\213 \330\250\330\247\331\206\330\252\331\207\330\247\330\241 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\210\330\256\330\261\331\210\330\254 \330\247\331\204\330\271\331\205\330\247\331\204 \331\210\331\205\330\271\330\247\331\204\330\254\330\251 \331\205\330\256\331\204\331\201\330\247\330\252 \330\247\331\204\331\204\330\255\330\247\331\205 \330\243\331\210 \330\247\331\204\331\202\330\267\330\271. \331\212\330\254\330\250 \330\271\331\204\331\211 \331\205\330\263\330\244\331\210\331\204 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 (HSE) \331\205\330\261\330\247\330\254\330\271\330\251 \331\205\330\255\331\212\330\267 \330\247\331\204\331\205\330\265\331\206\330\271 \331\210\330\252\330\243\331\203\331\212\330\257 \330\247\331\204\330\245\330\272\331\204\330\247\331\202 \331\210\330\247\331\204\330\243\330\261\330\264\331\201\330\251.\'"
