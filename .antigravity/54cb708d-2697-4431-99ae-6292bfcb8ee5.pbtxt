        }
        lines {
          text: "              {language === \'ar\'"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                ? \'\331\212\330\256\330\266\330\271 \331\205\331\210\331\202\330\271 \330\247\331\204\330\265\331\212\330\247\331\206\330\251 \331\204\331\205\330\261\330\247\331\202\330\250\330\251 \330\247\331\204\330\263\331\204\330\247\331\205\330\251 \330\247\331\204\330\257\330\247\330\246\331\205\330\251. \330\271\331\206\330\257 \330\247\331\204\330\247\331\206\330\252\331\207\330\247\330\241 \331\205\331\206 \330\247\331\204\330\271\331\205\331\204 \331\210\330\252\330\243\331\205\331\212\331\206 \330\247\331\204\331\205\330\271\330\257\330\247\330\252\330\214 \331\212\330\254\330\250 \330\271\331\204\331\211 \"\330\267\330\247\331\204\330\250 \330\247\331\204\330\252\330\265\330\261\331\212\330\255\" \330\252\331\202\330\257\331\212\331\205 \330\267\331\204\330\250 \330\245\330\272\331\204\330\247\331\202 \330\247\331\204\330\252\330\265\330\261\331\212\330\255 \331\204\331\204\331\205\330\261\330\247\330\254\330\271\330\251 \331\210\330\245\330\271\330\247\330\257\330\251 \331\202\331\201\331\204 \330\247\331\204\331\203\331\207\330\261\330\250\330\247\330\241.\'"
