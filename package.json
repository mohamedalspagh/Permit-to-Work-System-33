{
  "name": "permit-to-work-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm run start -w backend",
    "electron:start": "npm run electron:start -w frontend",
    "electron:build": "npm run electron:build -w frontend",
    "cap:sync": "npm run cap:sync -w frontend",
    "cap:open-android": "npm run cap:open-android -w frontend",
    "cap:open-ios": "npm run cap:open-ios -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
